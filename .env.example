SEEDGRAPH_LISTEN_ADDR=:8080
SEEDGRAPH_DATABASE_PATH=/data/seedgraph.db
SEEDGRAPH_WEB_DIR=/app/web
SEEDGRAPH_ADMIN_PASSWORD=change-me-now
SEEDGRAPH_SECRET_KEY=replace-with-at-least-32-random-characters
SEEDGRAPH_COOKIE_SECURE=false
SEEDGRAPH_SYNC_INTERVAL=30s
SEEDGRAPH_FULL_SYNC_INTERVAL=30m
SEEDGRAPH_STALE_AFTER=5m
SEEDGRAPH_IYUU_SYNC_ENABLED=true
SEEDGRAPH_IYUU_SYNC_INTERVAL=24h
SEEDGRAPH_IYUU_SITES_URL=https://2025.iyuu.cn/reseed/sites/index
